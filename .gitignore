# ==========================================
# EQEmu Server Binaries & Large Files
# ==========================================

# Compiled server executables & debug symbols
eqemu server/eqemu/*.exe
eqemu server/eqemu/*.exe.*
eqemu server/eqemu/*.pdb
eqemu server/eqemu/*.dll
eqemu server/eqemu/*.exp
eqemu server/eqemu/*.lib

# Shared memory (regenerated on server start, 620MB+)
eqemu server/eqemu/shared/

# Zone map files (1GB+, re-downloadable from PEQ)
eqemu server/eqemu/maps/

# Logs
eqemu server/eqemu/logs/
eqemu server/eqemu/out.txt
eqemu server/eqemu/err.txt

# ==========================================
# Database Files
# ==========================================

# Vanilla PEQ database install files (re-downloadable, 272MB+)
"eqemu server/peq/"

# Large generated SQL dumps
restore_point_*.sql
bound_items.sql
ethernaut_chief_items.sql
instance_all_zones.sql

# Raw database dump
restore_points/

# ==========================================
# DLL Build Artifacts (keep source, ignore compiled output)
# ==========================================

# Compiled output
eq-classless-dll-main/Release/
eq-classless-dll-main/eqgame_dll/Release/
eq-classless-dll-main/eqgame_dll/Debug/

# Build log noise
eq-classless-dll-main/build_output.txt
eq-classless-dll-main/build_win32.log

# Heavy SDK (re-downloadable)
eq-classless-dll-main/dxsdk81/

# Object files
**/*.obj
**/*.pdb
**/*.exp
**/*.lib
**/*.tlog
**/*.recipe
**/*.lastbuildstate

# ==========================================
# Game Client (not source, do not back up)
# ==========================================
everquest_rof2/

# ==========================================
# Antigravity AI Agent State
# (KI and conversation logs are local-only)
# ==========================================
.Antigravity/
.claude/
.agents/

# ==========================================
# Python Bytecode
# ==========================================
__pycache__/
*.pyc
*.pyo

# ==========================================
# Large text/data files that are output artifacts
# (generated by scripts, not source)
# ==========================================
all_items.txt
all_items_utf8.txt
modified_files.txt
grep_results.txt
search_results_v2.txt
ultimate_results.txt
epics_loose.txt
